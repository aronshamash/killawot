---
interface Props {
  name: string;
  image: string;
  description: string;
}

const { name, image, description } = Astro.props;
---

<div class="bg-navy-800/50 border border-white/5 rounded-2xl overflow-hidden hover:border-accent/20 transition-all duration-300">
  <div class="aspect-video bg-navy-700 overflow-hidden">
    <img
      src={image}
      alt={name}
      class="w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300"
      loading="lazy"
    />
  </div>
  <div class="p-6">
    <h3 class="text-white font-semibold text-lg mb-2">{name}</h3>
    <p class="text-gray-400 text-sm leading-relaxed">{description}</p>
  </div>
</div>
