---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Embedded AI Engineering',
    description: 'Senior engineers work inside your team to move AI projects from design to production. Hands-on delivery, not advisory slides.',
    deliverables: [
      'Claude and LLM integrations',
      'Agent systems and multi-agent orchestration',
      'MCP server implementation',
      'Workflow orchestration and automation',
      'Enterprise API integration',
      'Technical leadership and hands-on delivery',
    ],
    audience: 'Engineering teams that need senior AI delivery capacity without the overhead of hiring or onboarding a large agency.',
    icon: '<svg class="w-12 h-12 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 00.659 1.591L19 14.5M14.25 3.104c.251.023.501.05.75.082M19 14.5l-2.47 2.47a2.25 2.25 0 01-1.591.659H9.061a2.25 2.25 0 01-1.591-.659L5 14.5m14 0V5.846a2.25 2.25 0 00-1.36-2.068l-1.39-.58M5 14.5V5.846a2.25 2.25 0 011.36-2.068l1.39-.58" /></svg>',
  },
  {
    title: 'AI Platform Delivery',
    description: 'Architecture and implementation for organisations building internal AI capabilities. From agent runtime design to production hardening and handover.',
    deliverables: [
      'Agent runtime architecture',
      'Tool and data access design',
      'Auth, permissions and governance',
      'AWS deployment patterns',
      'Observability, tracing and monitoring',
      'Production hardening and handover',
    ],
    audience: 'Platform and infrastructure teams building foundational AI capabilities for internal product and data teams.',
    icon: '<svg class="w-12 h-12 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" /></svg>',
  },
  {
    title: 'AI Architecture Advisory',
    description: 'Senior technical guidance for organisations that need clarity before or during delivery. Architecture reviews, rescue work and decision support.',
    deliverables: [
      'Architecture reviews and design feedback',
      'AI readiness assessment',
      'Implementation rescue and recovery',
      'Roadmap and prioritisation',
      'Vendor and platform evaluation',
      'Risk and governance review',
    ],
    audience: 'CTOs, engineering directors and programme leads who need independent senior input before committing to a build, or who need to change direction mid-project.',
    icon: '<svg class="w-12 h-12 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>',
  },
];
---

<BaseLayout title="Enterprise AI Engineering Services | Killawot" description="Embedded AI engineering, AI platform delivery and architecture advisory. Senior engineers who ship production AI systems for complex organisations.">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://killawot.com/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://killawot.com/services/" }
    ]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Killawot Services",
    "url": "https://killawot.com/services/",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Service",
          "name": "Embedded AI Engineering",
          "description": "Senior engineers embedded with your team to move AI projects from design to production, including Claude and LLM integrations, agent systems, MCP server implementation and enterprise API integration.",
          "provider": { "@type": "Organization", "name": "Killawot", "url": "https://killawot.com" },
          "serviceType": "Embedded AI Engineering",
          "areaServed": "Worldwide"
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "Service",
          "name": "AI Platform Delivery",
          "description": "Architecture and implementation for organisations building internal AI capabilities, including agent runtime architecture, observability, governance and AWS deployment patterns.",
          "provider": { "@type": "Organization", "name": "Killawot", "url": "https://killawot.com" },
          "serviceType": "AI Platform Delivery",
          "areaServed": "Worldwide"
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "Service",
          "name": "AI Architecture Advisory",
          "description": "Senior technical guidance including architecture reviews, AI readiness assessment, implementation rescue, roadmap prioritisation and risk review.",
          "provider": { "@type": "Organization", "name": "Killawot", "url": "https://killawot.com" },
          "serviceType": "AI Architecture Advisory",
          "areaServed": "Worldwide"
        }
      }
    ]
  })} />
  <section class="pt-32 pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-3">What we offer</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Enterprise AI Engineering Services</h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          We design, build and ship production AI systems. Embedded engineering, platform delivery and architecture advisory, with senior engineers on every engagement.
        </p>
      </div>

      <div class="space-y-12">
        {services.map((service) => (
          <div class="bg-navy-800/50 border border-white/5 rounded-2xl p-8 md:p-12 hover:border-accent/20 transition-all duration-300">
            <div class="flex items-start gap-6">
              <div class="hidden md:block shrink-0" set:html={service.icon} />
              <div class="flex-1">
                <h2 class="text-2xl font-bold text-white mb-4">{service.title}</h2>
                <p class="text-gray-400 leading-relaxed mb-6">{service.description}</p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div>
                    <h3 class="text-white text-sm font-semibold uppercase tracking-wider mb-3">Key deliverables</h3>
                    <ul class="space-y-2">
                      {service.deliverables.map((item) => (
                        <li class="flex items-start gap-2 text-sm text-gray-400">
                          <svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                          </svg>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <h3 class="text-white text-sm font-semibold uppercase tracking-wider mb-3">Who it's for</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">{service.audience}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-16">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-accent hover:bg-accent-light text-navy-950 font-semibold rounded-xl transition-colors"
        >
          Book a technical discovery call
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
