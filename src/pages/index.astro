---
import BaseLayout from '../layouts/BaseLayout.astro';

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Killawot',
  url: 'https://killawot.com',
  description: 'Embedded AI engineering consultancy delivering production AI systems, agent architecture, MCP integrations and enterprise APIs for complex organisations.',
  serviceArea: 'Worldwide',
  knowsAbout: ['Embedded AI Engineering', 'Agent Systems', 'MCP Integrations', 'Enterprise API Integration', 'LLM Integration', 'Observability', 'AWS Architecture', 'AI Governance'],
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Killawot',
  url: 'https://killawot.com',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://killawot.com/?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

const services = [
  {
    title: 'Embedded AI Engineering',
    description: 'Senior engineers embedded with your team to move AI projects from design to production. Hands-on delivery, not advisory slides.',
  },
  {
    title: 'AI Platform Delivery',
    description: 'Architecture and implementation for teams building internal AI capabilities, including agent runtimes, observability, governance and AWS deployment.',
  },
  {
    title: 'AI Architecture Advisory',
    description: 'Senior technical guidance for organisations that need clarity before or during delivery. Architecture reviews, rescue work and decision support.',
  },
];

const clients = ['Collinson Group', 'BBC iPlayer', 'The Times'];

const capabilities = [
  'Production APIs and enterprise integration platforms',
  'AWS cloud infrastructure and event-driven systems',
  'Identity, access control and governance',
  'Observability, tracing and monitoring',
  'Human-in-the-loop workflows',
  'Handover documentation and team enablement',
];
---

<BaseLayout title="Killawot | Embedded AI Engineering for Enterprise Delivery">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

  <!-- Hero -->
  <section class="relative pt-36 pb-28 md:pt-52 md:pb-36 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-900 via-navy-950 to-navy-950" />
    <div class="absolute inset-0 opacity-[0.035]" style="background-image: radial-gradient(circle, #00b4d8 1px, transparent 1px); background-size: 40px 40px;" />
    <div class="absolute top-1/3 left-1/4 w-80 h-80 bg-accent/10 rounded-full blur-3xl pointer-events-none" />
    <div class="absolute bottom-1/4 right-1/4 w-56 h-56 bg-cyan-400/10 rounded-full blur-3xl pointer-events-none" />

    <div class="relative max-w-5xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-accent/25 bg-accent/10 text-accent text-xs font-semibold uppercase tracking-wider mb-8">
        Enterprise AI Engineering
      </div>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white leading-[1.05] tracking-tight mb-6">
        Embedded AI engineering<br />
        <span class="bg-gradient-to-r from-accent to-cyan-400 bg-clip-text text-transparent">
          for enterprise delivery
        </span>
      </h1>
      <p class="text-gray-400 text-lg md:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
        Killawot helps organisations design, build and ship production AI systems, from agent architecture and MCP integrations to enterprise APIs, observability and handover.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-accent hover:bg-accent-light text-navy-950 font-semibold rounded-xl transition-colors"
        >
          Discuss an AI delivery project
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/work"
          class="inline-flex items-center justify-center px-8 py-3.5 border border-white/10 text-white hover:border-white/25 rounded-xl transition-colors"
        >
          View our work
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-24 bg-navy-950 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-end justify-between mb-14">
        <div>
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-accent/25 bg-accent/10 text-accent text-xs font-semibold uppercase tracking-wider mb-4">
            What we do
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-white">Services</h2>
        </div>
        <a
          href="/services"
          class="hidden md:inline-flex items-center gap-1.5 text-accent hover:text-accent-light text-sm font-medium transition-colors"
        >
          View all services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="divide-y divide-white/5">
        {services.map((service, i) => (
          <div class="flex items-start gap-8 py-8 first:pt-0 last:pb-0">
            <span class="hidden md:block font-bold tabular-nums w-12 shrink-0 pt-1.5 text-accent/20 text-2xl leading-none">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex-1 min-w-0">
              <h3 class="text-white text-xl font-semibold mb-2">{service.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed max-w-2xl">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-10 md:hidden">
        <a
          href="/services"
          class="inline-flex items-center gap-1.5 text-accent hover:text-accent-light text-sm font-medium transition-colors"
        >
          View all services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Credibility -->
  <section class="py-24 bg-navy-900 border-y border-white/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-accent/25 bg-accent/10 text-accent text-xs font-semibold uppercase tracking-wider mb-4">
          Why teams choose Killawot
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Built for real enterprise complexity</h2>
        <p class="text-gray-400 text-base max-w-xl mx-auto">
          We bring senior engineering depth to AI delivery, not prototypes, but production systems designed for real organisational constraints.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 max-w-4xl mx-auto mb-10">
        {capabilities.map((item) => (
          <div class="flex items-start gap-3 bg-navy-800/40 border border-white/5 rounded-xl px-4 py-3.5">
            <svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-300 text-sm leading-snug">{item}</span>
          </div>
        ))}
      </div>
      <div class="max-w-2xl mx-auto pt-8 border-t border-white/10">
        <p class="text-gray-400 text-sm text-center leading-relaxed">
          We work with modern AI ecosystems including Claude, MCP, AWS and enterprise integration platforms. Killawot is working toward formal accreditation in the Anthropic ecosystem.
        </p>
      </div>
    </div>
  </section>

  <!-- Trusted By -->
  <section class="py-20 bg-navy-950">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-gray-600 text-xs font-semibold uppercase tracking-widest mb-10">Engineering for global organisations</p>
      <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
        {clients.map((name, i) => (
          <div class="flex items-center gap-10">
            <span class="text-white text-xl font-semibold tracking-tight">{name}</span>
            {i < clients.length - 1 && <span class="w-px h-5 bg-white/10 hidden sm:block" aria-hidden="true" />}
          </div>
        ))}
      </div>
      <div class="mt-10">
        <a
          href="/work"
          class="inline-flex items-center gap-1.5 text-accent hover:text-accent-light text-sm font-medium transition-colors"
        >
          See our work
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-32 bg-navy-950 border-t border-white/5 overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="w-[600px] h-[300px] bg-accent/10 rounded-full blur-3xl" />
    </div>
    <div class="relative max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-5 tracking-tight">
        Ready to ship production AI?
      </h2>
      <p class="text-gray-400 text-base mb-10 leading-relaxed max-w-lg mx-auto">
        Whether you need embedded engineers, platform architecture, or a senior technical review, we help you move from design to delivery with confidence.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-accent hover:bg-accent-light text-navy-950 font-semibold rounded-xl transition-colors"
      >
        Book a technical discovery call
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
