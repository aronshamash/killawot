---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — Killawot" description="The page you were looking for doesn't exist. Head back to Killawot to explore our AI automation and development services.">
  <section class="pt-32 pb-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-6">404</p>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">Page not found</h1>
      <p class="text-gray-400 text-lg mb-10">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center justify-center px-8 py-3.5 bg-accent hover:bg-accent-light text-navy-950 font-semibold rounded-xl transition-colors">
          Back to home
        </a>
        <a href="/services" class="inline-flex items-center justify-center px-8 py-3.5 border border-white/10 text-white hover:border-accent/50 rounded-xl transition-colors">
          Our services
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
