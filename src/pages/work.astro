---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClientCard from '../components/ClientCard.astro';

const projects = [
  {
    name: 'Collinson Group',
    image: '/images/clients/collinson-group.jpg',
    description: 'Platform modernisation for the group behind Priority Pass — the world\'s largest airport lounge network, serving over 25 million members globally. Rebuilt core platform services with event-driven architecture on AWS and automated CI/CD delivery pipelines. Delivered measurable improvements in release velocity and platform reliability across a high-availability system operating at significant scale.',
  },
  {
    name: 'Superdry',
    image: '/images/clients/superdry.png',
    description: 'Re-platforming and new feature development for the global fashion retailer operating across 65 countries. Full-stack engineering across their e-commerce platform using Node.js and React, including checkout flow improvements, performance optimisation, and integration work with third-party fulfilment and payments systems.',
  },
  {
    name: 'The Times Newspaper',
    image: '/images/clients/thetimes.jpg',
    description: 'Software development for one of the world\'s most recognised news publications, with a digital subscriber base in the millions. Built and maintained tooling for the digital publishing workflow, enabling the editorial team to publish high-frequency content reliably across web and app platforms at pace.',
  },
  {
    name: 'BBC iPlayer',
    image: '/images/clients/iplayer.jpg',
    description: 'Engineering for BBC iPlayer — the UK\'s leading on-demand streaming platform, serving millions of viewers daily. Built resilient, high-throughput backend services on AWS designed to handle peak demand during major live events and sustained on-demand streaming load without degradation.',
  },
  {
    name: 'Rebecca Shamash',
    image: '/images/clients/rebecca.png',
    description: 'Design and build of a professional website for a psychotherapist practice in Bristol. Built with Astro for fast static delivery, with structured local SEO markup, accessible design, and a clean UX focused on building client trust and driving contact enquiries.',
  },
];
---

<BaseLayout title="Our Work — AI & Engineering Projects — Killawot" description="Case studies from 20+ years engineering for global brands — Collinson Group, BBC iPlayer, The Times, Superdry, and more.">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://killawot.com/" },
      { "@type": "ListItem", "position": 2, "name": "Work", "item": "https://killawot.com/work/" }
    ]
  })} />
  <section class="pt-32 pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-3">Our portfolio</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Engineering Projects & Client Work</h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          Selected projects from over 20 years of engineering for global brands and growing businesses.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <ClientCard {...project} />
        ))}
      </div>

      <div class="text-center mt-16">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-accent hover:bg-accent-light text-navy-950 font-semibold rounded-xl transition-colors"
        >
          Start a project
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
