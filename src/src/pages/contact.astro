---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Killawot">
  <section class="pt-32 pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-3">Let's talk</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Get in touch</h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          Whether you're exploring AI automation, need a technical audit, or want to build something new — let's discuss how we can help.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Form -->
        <div class="md:col-span-2">
          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-300 mb-2">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 bg-navy-800 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 bg-navy-800 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors"
                  placeholder="you@company.com"
                />
              </div>
            </div>

            <div>
              <label for="company" class="block text-sm font-medium text-gray-300 mb-2">Company</label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full px-4 py-3 bg-navy-800 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors"
                placeholder="Your company (optional)"
              />
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-gray-300 mb-2">Service interest</label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 bg-navy-800 border border-white/10 rounded-xl text-white focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors"
              >
                <option value="">Select a service...</option>
                <option value="ai-automation">AI Automation Consulting</option>
                <option value="ai-audit">AI Audit & Readiness Assessment</option>
                <option value="development">Full-Stack Development</option>
                <option value="cloud">Cloud Architecture</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-300 mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 bg-navy-800 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors resize-none"
                placeholder="Tell us about your project or challenge..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full sm:w-auto px-8 py-3.5 bg-accent hover:bg-accent-light text-navy-950 font-semibold rounded-xl transition-colors"
            >
              Send message
            </button>

            <div id="form-status" class="hidden mt-4 p-4 rounded-xl text-sm"></div>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8">
          <div>
            <h3 class="text-white font-semibold mb-2">Email</h3>
            <a href="mailto:info@killawot.com" class="text-accent hover:text-accent-light transition-colors">
              info@killawot.com
            </a>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-2">Phone</h3>
            <p class="text-gray-400">+44 (0)7947 408 351</p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-2">Based in</h3>
            <p class="text-gray-400">London, UK</p>
          </div>
          <div class="pt-4 border-t border-white/5">
            <p class="text-gray-500 text-sm">
              Free initial consultation to discuss your requirements and explore how we can help.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLDivElement;

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Sending...';
    submitBtn.disabled = true;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        status.className = 'mt-4 p-4 rounded-xl text-sm bg-green-900/30 border border-green-500/30 text-green-400';
        status.textContent = 'Message sent successfully. We\'ll be in touch soon.';
        form.reset();
      } else {
        throw new Error('Failed to send');
      }
    } catch {
      status.className = 'mt-4 p-4 rounded-xl text-sm bg-red-900/30 border border-red-500/30 text-red-400';
      status.textContent = 'Something went wrong. Please email us directly at info@killawot.com';
    } finally {
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
      status.classList.remove('hidden');
    }
  });
</script>
